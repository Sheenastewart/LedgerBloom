# Docker Compose placeholders for local development only.
# Copy this file to .env and replace the values before running docker compose.
# Do not commit the real .env file.

POSTGRES_DB=ledgerbloom
POSTGRES_USER=ledgerbloom
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Backend shell exports used with ./mvnw spring-boot:run
# (Spring Boot does not load the root .env automatically.)
# export DB_URL=jdbc:postgresql://localhost:5432/ledgerbloom
# export DB_USERNAME=ledgerbloom
# export DB_PASSWORD=change-me

# --- Account Management / production security (placeholders only) ---
# Comma-separated exact frontend origins. Never use "*".
# export LEDGERBLOOM_CORS_ALLOWED_ORIGINS=http://localhost:5173
# Session cookie / timeout (local defaults keep http://localhost:5173 working)
# export LEDGERBLOOM_SESSION_TIMEOUT=30m
# export LEDGERBLOOM_SESSION_COOKIE_HTTP_ONLY=true
# export LEDGERBLOOM_SESSION_COOKIE_SAME_SITE=lax
# export LEDGERBLOOM_SESSION_COOKIE_SECURE=false
# Production HTTPS: set cookie Secure=true and SameSite as required by your hosting model.
# export LEDGERBLOOM_REQUIRE_HTTPS=false
# Local-only password-reset helpers (keep false in production; never log or commit tokens)
# export LEDGERBLOOM_DEV_RETURN_RESET_TOKEN=false
# export LEDGERBLOOM_DEV_RESET_INBOX_ENABLED=false
# export LEDGERBLOOM_PASSWORD_RESET_TOKEN_TTL=1h
# Login throttling (in-memory; single-instance only)
# export LEDGERBLOOM_LOGIN_MAX_FAILURES=5
# export LEDGERBLOOM_LOGIN_COOLDOWN=15m
